# DevPulse Phase 1 Environment Configuration
# Copy this to .env and fill in your values

# ── Google Cloud ─────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Dynatrace ────────────────────────────────────────────────────────
# Get these from: Dynatrace → Settings → Integration → Platform as a Service
DYNATRACE_ENVIRONMENT_ID=abc12345.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# ── Optional: Dynatrace API for programmatic access ──────────────────
# Get this from: Dynatrace → Access Tokens → Generate Token
# Required scopes: problems.read, entities.read, metrics.read, logs.read
DYNATRACE_API_KEY=dt0c01.XXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# ── Webhook Configuration (for Phase 2) ──────────────────────────────
# Will be populated after deploying webhook-receiver
WEBHOOK_RECEIVER_URL=
