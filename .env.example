# DevPulse — root .env.example
# Copy to .env and fill in all values before deploying.
# Never commit .env to the repo.

# ── Firebase / Firestore ──────────────────────────────────────────
FIRESTORE_PROJECT_ID=your-firebase-project-id

# ── Google Cloud Agent Builder ────────────────────────────────────
AGENT_BUILDER_PROJECT=your-gcp-project-id
AGENT_BUILDER_LOCATION=us-central1
AGENT_BUILDER_AGENT_ID=your-agent-builder-agent-id

# ── Dynatrace ─────────────────────────────────────────────────────
DYNATRACE_BASE_URL=https://YOUR_ENV_ID.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXX

# ── GitHub ────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXX
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=devpulse-demo-api

# ── Slack ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXX-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_SIGNING_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── Dashboard (Next.js public env vars) ───────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:XXXXXXXXXXXX:web:XXXXXXXXXXXXXXXXXXXXXXXX
